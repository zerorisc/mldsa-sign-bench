--- a/ref/sign.c
+++ b/ref/sign.c
@@ -71,8 +71,18 @@ int crypto_sign_keypair(uint8_t *pk, uint8_t *sk) {
 *
 * Description: Computes signature. Internal API.
 *
+* The iteration record is a sequence of bytes where each byte represents an
+* rejected iteration of the sign loop. If the pointer is NULL, no iteration
+* record is created. The byte indicates why the signature was rejected:
+*   - 0: z failed chknorm
+*   - 1: w0 failed chknorm
+*   - 2: ct0 failed chknorm
+*   - 3: h failed chknorm
+*
 * Arguments:   - uint8_t *sig:   pointer to output signature (of length CRYPTO_BYTES)
 *              - size_t *siglen: pointer to output length of signature
+*              - uint8_t *iter:  pointer to iteration record
+*              - size_t *iterlen: pointer to length of iteration record
 *              - uint8_t *m:     pointer to message to be signed
 *              - size_t mlen:    length of message
 *              - uint8_t *pre:   pointer to prefix string
@@ -84,6 +94,8 @@ int crypto_sign_keypair(uint8_t *pk, uint8_t *sk) {
 **************************************************/
 int crypto_sign_signature_internal(uint8_t *sig,
                                    size_t *siglen,
+                                   uint8_t *iter,
+                                   size_t *iterlen,
                                    const uint8_t *m,
                                    size_t mlen,
                                    const uint8_t *pre,
@@ -95,6 +107,9 @@ int crypto_sign_signature_internal(uint8_t *sig,
   uint8_t seedbuf[2*SEEDBYTES + TRBYTES + 2*CRHBYTES];
   uint8_t *rho, *tr, *key, *mu, *rhoprime;
   uint16_t nonce = 0;
+  if (iter != NULL) {
+     *iterlen = 0;
+  }
   polyvecl mat[K], s1, y, z;
   polyveck t0, s2, w1, w0, h;
   poly cp;
@@ -158,8 +173,14 @@ rej:
   polyvecl_invntt_tomont(&z);
   polyvecl_add(&z, &z, &y);
   polyvecl_reduce(&z);
-  if(polyvecl_chknorm(&z, GAMMA1 - BETA))
+  if(polyvecl_chknorm(&z, GAMMA1 - BETA)) {
+    if (iter != NULL) {
+      iter[0] = 0;
+      iter++;
+      (*iterlen)++;
+    }
     goto rej;
+  }
 
   /* Check that subtracting cs2 does not change high bits of w and low bits
    * do not reveal secret information */
@@ -167,20 +188,38 @@ rej:
   polyveck_invntt_tomont(&h);
   polyveck_sub(&w0, &w0, &h);
   polyveck_reduce(&w0);
-  if(polyveck_chknorm(&w0, GAMMA2 - BETA))
+  if(polyveck_chknorm(&w0, GAMMA2 - BETA)) {
+    if (iter != NULL) {
+      iter[0] = 1;
+      iter++;
+      (*iterlen)++;
+    }
     goto rej;
+  }
 
   /* Compute hints for w1 */
   polyveck_pointwise_poly_montgomery(&h, &cp, &t0);
   polyveck_invntt_tomont(&h);
   polyveck_reduce(&h);
-  if(polyveck_chknorm(&h, GAMMA2))
+  if(polyveck_chknorm(&h, GAMMA2)) {
+    if (iter != NULL) {
+      iter[0] = 2;
+      iter++;
+      (*iterlen)++;
+    }
     goto rej;
+  }
 
   polyveck_add(&w0, &w0, &h);
   n = polyveck_make_hint(&h, &w0, &w1);
-  if(n > OMEGA)
+  if(n > OMEGA) {
+    if (iter != NULL) {
+      iter[0] = 3;
+      iter++;
+      (*iterlen)++;
+    }
     goto rej;
+  }
 
   /* Write signature */
   pack_sig(sig, sig, &z, &h);
