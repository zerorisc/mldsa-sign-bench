     rnd[i] = 0;
 #endif
 
-  crypto_sign_signature_internal(sig,siglen,m,mlen,pre,2+ctxlen,rnd,sk);
+  crypto_sign_signature_internal(sig,siglen,NULL,NULL,m,mlen,pre,2+ctxlen,rnd,sk);
